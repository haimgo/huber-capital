---
const { image = '/assets/about.jpg', showLink = true } = Astro.props;
---
<section class="py-24 md:py-32 border-b hair reveal">
  <div class="max-w-container mx-auto px-6 sm:px-8 grid md:grid-cols-2 gap-14 lg:gap-24 items-center">
    <div class="relative order-2 md:order-1">
      <img src={image} alt="גלעד הובר" class="w-full aspect-[4/5] object-cover lux-img" />
      <div class="absolute -bottom-6 -left-6 w-44 h-44 border border-gold/30"></div>
    </div>
    <div class="order-1 md:order-2 text-right">
      <p class="tracking-[.4em] uppercase text-gold text-[12px] mb-6">מי אנחנו</p>
      <h2 class="font-head text-4xl md:text-5xl leading-tight mb-8">גלעד הובר</h2>
      <div class="w-20 h-px bg-gold/60 mb-9"></div>
      <p class="font-light text-ivory/75 text-lg leading-[1.95] mb-6">30 שנות ניסיון בעולם העסקים. לאחר שהעברתי את מרכז חיי לדובאי — ההחלטה הכי טובה שעשיתי — אני מלווה משקיעים ישראלים בגישה שמתחילה ונגמרת באינטרס שלהם.</p>
      <p class="font-light text-ivory/75 text-lg leading-[1.95] mb-9">צוות מקומי בדובאי, גישה לפרויקטים במחיר מתחת לשוק, ותהליך מדויק של בחירה, בדיקה וביצוע.</p>
      {showLink && <a href="/about" class="text-[11px] tracking-[.3em] uppercase border-b border-gold/40 pb-1.5 hover:text-gold transition">עוד עליי ועל הצוות</a>}
    </div>
  </div>
</section>
