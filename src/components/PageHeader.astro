---
const { eyebrow, title, sub } = Astro.props;
---
<section class="px-6 pt-16 md:pt-24 pb-10 text-center">
  <p class="eyebrow text-[11px] md:text-sm mb-6" style="color:#7fe9ff;">{eyebrow}</p>
  <h1 class="font-display font-bold text-4xl md:text-7xl mb-6 neon glow" set:html={title}></h1>
  {sub && <p class="text-mute text-lg max-w-2xl mx-auto font-light">{sub}</p>}
</section>
