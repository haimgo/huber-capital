---
// "הגישה שלי פשוטה" approach banner — styled to the site (dark + gold-neon),
// with gold accent lines and a soft glow. Texts are passed in (editable via
// the page_sections "home" group; bilingual via pageText).
const { title, line1, line2, body } = Astro.props;
---
<section class="relative px-6 py-24 md:py-32 reveal overflow-hidden">
  <div class="pointer-events-none absolute inset-0 flex items-center justify-center" aria-hidden="true">
    <div class="w-[70%] h-[70%] rounded-full opacity-[0.06] blur-3xl" style="background:radial-gradient(circle, #ffd24a 0%, transparent 70%)"></div>
  </div>
  <div class="relative max-w-4xl mx-auto text-center">
    <div class="h-px w-44 mx-auto mb-14 bg-gradient-to-r from-transparent via-cyan/70 to-transparent"></div>
    <h2 class="font-display font-extrabold text-4xl md:text-6xl mb-12 neon glow">{title}</h2>
    <p class="font-display font-bold text-2xl md:text-4xl text-fg mb-2 leading-tight">{line1}</p>
    <p class="font-display font-bold text-2xl md:text-4xl neon glow mb-10 leading-tight">{line2}</p>
    <p class="text-mute font-light text-lg md:text-xl leading-[1.9] max-w-2xl mx-auto">{body}</p>
    <div class="h-px w-44 mx-auto mt-14 bg-gradient-to-r from-transparent via-cyan/70 to-transparent"></div>
  </div>
</section>
