---
// "הגישה שלי פשוטה" approach banner — clean centered statement (same style as the
// former manifesto). Texts are editable + bilingual via the page_sections "home" group.
const { title, line1, line2, body } = Astro.props;
---
<section class="px-6 py-20 md:py-28 text-center reveal">
  <div class="max-w-4xl mx-auto">
    <h2 class="font-display font-bold text-3xl md:text-5xl leading-tight neon glow">{title}</h2>
    <p class="font-display font-semibold text-2xl md:text-3xl text-fg mt-7 leading-tight">{line1}</p>
    <p class="font-display font-semibold text-2xl md:text-3xl neon mt-1 leading-tight">{line2}</p>
    <p class="text-mute font-light text-lg mt-7 max-w-2xl mx-auto leading-relaxed">{body}</p>
  </div>
</section>
