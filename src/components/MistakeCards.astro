---
const {
  mistakes,
  eyebrow = 'לפני שמשקיעים',
  heading = 'שלוש טעויות שעולות למשקיעים ביוקר',
  closing = 'הליווי שלנו נועד למנוע בדיוק את אלה.',
} = Astro.props;
const svg = (p: string) =>
  `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">${p}</svg>`;
// One icon per mistake (by order): unstable developer, wrong project, inaccurate data.
const ICONS = [
  svg('<path d="m21.73 18-8-14a2 2 0 0 0-3.46 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" x2="12" y1="9" y2="13"/><line x1="12" x2="12.01" y1="17" y2="17"/>'),
  svg('<circle cx="12" cy="12" r="10"/><line x1="15" x2="9" y1="9" y2="15"/><line x1="9" x2="15" y1="9" y2="15"/>'),
  svg('<polyline points="22 17 13.5 8.5 8.5 13.5 2 7"/><polyline points="16 17 22 17 22 11"/>'),
];
---
<section class="px-6 py-16 md:py-24">
  <div class="max-w-container mx-auto">
    <div class="text-center mb-12 reveal">
      <p class="eyebrow text-[11px] mb-3" style="color:#ffc46a;">{eyebrow}</p>
      <h2 class="font-display font-bold text-3xl md:text-5xl">{heading}</h2>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      {mistakes.map((m, i) => (
        <div class="glass rounded-3xl p-8 text-start reveal transition duration-300 hover:border-magenta/40 hover:shadow-[0_0_30px_-6px_rgba(255,157,47,0.24)]" style={`transition-delay:${i * 0.08}s`}>
          <div class="flex items-start justify-between mb-4">
            <span class="font-display font-extrabold text-4xl neon glow leading-none">{m.n}</span>
            <span class="text-magenta/70 shrink-0 mt-1" set:html={ICONS[i % ICONS.length]}></span>
          </div>
          <h3 class="font-display font-semibold text-2xl mb-2">{m.title}</h3>
          <p class="text-mute font-light leading-relaxed">{m.text}</p>
        </div>
      ))}
    </div>
    {closing && <p class="text-center text-fg/80 font-light text-lg mt-10 reveal">{closing}</p>}
  </div>
</section>
