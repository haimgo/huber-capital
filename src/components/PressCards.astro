---
const { press, eyebrow = 'בתקשורת', heading = 'מדברים עלינו' } = Astro.props;
---
<section class="px-6 py-16 md:py-24">
  <div class="max-w-container mx-auto">
    <div class="text-center mb-12 reveal">
      <p class="eyebrow text-[11px] mb-3" style="color:#7fe9ff;">{eyebrow}</p>
      <h2 class="font-display font-bold text-3xl md:text-5xl">{heading}</h2>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      {press.map((p, i) => (
        <a href={p.url} class="glass rounded-3xl p-8 text-right reveal block transition hover:border-cyan/40" style={`transition-delay:${i * 0.08}s`}>
          <span class="eyebrow text-[10px] text-cyan">{p.outlet}</span>
          <p class="font-display font-semibold text-2xl mt-3 leading-snug">&ldquo;{p.title}&rdquo;</p>
          <span class="eyebrow text-mute text-[10px] mt-5 inline-block">לכתבה ←</span>
        </a>
      ))}
    </div>
  </div>
</section>
