---
const { press, eyebrow = 'בתקשורת', heading = '', lang = 'he' } = Astro.props;
const readMore = lang === 'ru' ? 'К статье →' : 'לכתבה ←';
---
<section class="px-6 py-16 md:py-24">
  <div class="max-w-container mx-auto">
    {(eyebrow || heading) && (
      <div class="text-center mb-12 reveal">
        {eyebrow && <p class="eyebrow text-[11px] mb-3" style="color:#ffd98a;">{eyebrow}</p>}
        {heading && <h2 class="font-display font-bold text-3xl md:text-5xl" set:html={heading}></h2>}
      </div>
    )}
    <div class="grid md:grid-cols-3 gap-6">
      {press.map((p, i) => (
        <a href={p.url} target="_blank" rel="noopener" class="glass rounded-3xl p-8 text-start reveal block transition hover:border-cyan/40" style={`transition-delay:${i * 0.08}s`}>
          <span class="eyebrow text-[10px] text-cyan">{p.outlet}</span>
          <p class="font-display font-semibold text-2xl mt-3 leading-snug">&ldquo;{p.title}&rdquo;</p>
          <span class="eyebrow text-mute text-[10px] mt-5 inline-block">{readMore}</span>
        </a>
      ))}
    </div>
  </div>
</section>
