---
const { stats, eyebrow, heading } = Astro.props;
const hasHead = Boolean(eyebrow || heading);
---
<section class="px-6 py-16 md:py-20 reveal">
  <div class="max-w-container mx-auto">
    {hasHead && (
      <div class="text-center mb-10">
        {eyebrow && <p class="eyebrow text-[11px] mb-3" style="color:#7fe9ff;">{eyebrow}</p>}
        {heading && <h2 class="font-display font-bold text-3xl md:text-4xl">{heading}</h2>}
      </div>
    )}
    <div class="glass rounded-[28px] p-8 md:p-12">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        {stats.map((s) => (
          <div>
            <div class="font-display font-extrabold text-4xl md:text-5xl neon glow mb-2">{s.value}</div>
            <div class="eyebrow text-[9px] text-mute">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
