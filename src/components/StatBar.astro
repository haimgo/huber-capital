---
const { stats, eyebrow, heading } = Astro.props;
const hasHead = Boolean(eyebrow || heading);
---
<section class="border-b hair reveal">
  {hasHead && (
    <div class="max-w-container mx-auto px-6 sm:px-8 pt-20 pb-6 text-center">
      {eyebrow && <p class="tracking-[.4em] uppercase text-gold text-[12px] mb-4">{eyebrow}</p>}
      {heading && <h2 class="font-head text-3xl md:text-4xl">{heading}</h2>}
    </div>
  )}
  <div class={`max-w-container mx-auto px-6 sm:px-8 grid grid-cols-2 md:grid-cols-4 ${hasHead ? 'border-t hair' : ''}`}>
    {stats.map((s, i) => (
      <div class={`py-12 md:py-14 text-center ${i < 3 ? 'md:border-l hair' : ''} ${i < 2 ? 'border-b md:border-b-0' : ''}`}>
        <div class="font-cormorant text-4xl md:text-5xl text-gold mb-3">{s.value}</div>
        <div class="tracking-[.24em] uppercase text-[11px] text-mute">{s.label}</div>
      </div>
    ))}
  </div>
</section>
