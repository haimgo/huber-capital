---
import { site } from '../data/site.js';
const base = import.meta.env.BASE_URL.replace(/\/$/, '') + '/';
const link = (h) => (h === '/' ? base : base + h.replace(/^\//, '') + '/');
const year = 2026;
---
<footer class="px-6 pb-12 pt-10">
  <div class="max-w-container mx-auto glass rounded-[28px] p-10 md:p-12">
    <div class="grid md:grid-cols-4 gap-10 text-right">
      <div class="md:col-span-2">
        <div class="flex flex-row-reverse items-center gap-3 mb-5 justify-end md:justify-start">
          <span class="w-2 h-2 rounded-full" style="background:#ffd24a;box-shadow:0 0 12px #ffd24a;"></span>
          <span class="eyebrow text-sm neon">HUBER CAPITAL</span>
        </div>
        <p class="text-mute font-light leading-relaxed max-w-sm">ליווי משקיעים ישראלים בהשקעות נדל"ן בדובאי — מאפיון ועד ביצוע, בגישה שמתחילה ונגמרת באינטרס שלכם.</p>
      </div>
      <div>
        <h4 class="eyebrow text-[10px] text-cyan mb-4">ניווט</h4>
        <ul class="space-y-3 text-mute text-sm font-light">
          <li><a href={link('/investment')} class="hover:text-fg transition">השקעה בדובאי</a></li>
          <li><a href={link('/process')} class="hover:text-fg transition">התהליך</a></li>
          <li><a href={link('/projects')} class="hover:text-fg transition">פרויקטים</a></li>
          <li><a href={link('/press')} class="hover:text-fg transition">בתקשורת</a></li>
        </ul>
      </div>
      <div>
        <h4 class="eyebrow text-[10px] text-cyan mb-4">קשר</h4>
        <a href={site.phoneHref} dir="ltr" class="block text-fg text-sm hover:text-cyan transition">{site.phone}</a>
        <a href={site.whatsapp} class="block text-mute text-sm font-light mt-2 hover:text-fg transition">וואטסאפ</a>
        <p class="text-mute text-sm font-light mt-2">{site.location}</p>
      </div>
    </div>
    <div class="border-t border-white/10 mt-10 pt-6 flex flex-col md:flex-row-reverse justify-between gap-4 text-[10px] text-mute">
      <span class="eyebrow">© {year} Huber Capital · {site.owner}</span>
      <div class="flex flex-row-reverse gap-5">
        <a href={link('/legal/privacy')} class="hover:text-fg transition">פרטיות</a>
        <a href={link('/legal/terms')} class="hover:text-fg transition">תקנון</a>
        <a href={link('/legal/accessibility')} class="hover:text-fg transition">נגישות</a>
      </div>
    </div>
    <p class="text-mute/60 text-[10px] font-light leading-relaxed mt-5 text-right max-w-3xl">* אין באמור משום הבטחת תשואה או ייעוץ השקעות. השקעה בנדל"ן בחו"ל כרוכה בסיכון. הנתונים מובאים לצורכי המחשה בלבד.</p>
  </div>
</footer>
