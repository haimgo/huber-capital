---
import { site } from '../data/site.js';
import { brandIcon } from '../lib/icons';
import { serverClient } from '../lib/supabase';
import { getSettings } from '../lib/content';
import { t, localizePath, stripLocale, type Lang } from '../lib/i18n';
const { lang = 'he' } = Astro.props as { lang?: Lang };
const base = import.meta.env.BASE_URL.replace(/\/$/, '') + '/';
const href = (h: string, l: Lang = lang) => {
  const loc = localizePath(h, l);
  if (loc === '/') return base;
  return base + loc.replace(/^\/+/, '') + (loc.endsWith('/') ? '' : '/');
};
let raw = Astro.url.pathname;
if (base !== '/' && raw.startsWith(base)) raw = '/' + raw.slice(base.length);
const { path: logical0 } = stripLocale(raw);
const path = logical0.replace(/\/+$/, '') || '/';
const year = 2026;
// Social links come from site_settings (editable in /admin → הגדרות); empty = hidden.
const settings = await getSettings(serverClient(Astro.cookies));
const social = [
  { name: 'facebook', label: 'Facebook', url: settings?.social_facebook },
  { name: 'instagram', label: 'Instagram', url: settings?.social_instagram },
  { name: 'youtube', label: 'YouTube', url: settings?.social_youtube },
  { name: 'tiktok', label: 'TikTok', url: settings?.social_tiktok },
].filter((s) => s.url && String(s.url).trim());
---
<footer class="px-6 pb-12 pt-10">
  <div class="max-w-container mx-auto glass rounded-[28px] p-10 md:p-12">
    <div class="grid md:grid-cols-4 gap-10 text-start">
      <div class="md:col-span-2">
        <div class="flex rtl:flex-row-reverse items-center gap-3 mb-5 justify-end md:justify-start">
          <img src={`${base}assets/logo-mark.png`} alt="Huber Capital" width="132" height="57" class="h-10 w-auto drop-shadow-[0_0_12px_rgba(255,210,74,0.35)]" />
          <span class="eyebrow text-sm neon">HUBER CAPITAL</span>
        </div>
        <p class="text-mute font-light leading-relaxed max-w-sm">{t(lang, 'footer_blurb')}</p>
        <div class="flex items-center gap-1.5 mt-6 text-[10px] eyebrow" aria-label={t(lang, 'lang_switch')}>
          <a href={href(path, 'he')} hreflang="he" class={lang === 'he' ? 'text-cyan' : 'text-mute hover:text-fg transition'}>{t(lang, 'lang_he')}</a>
          <span class="text-mute/40" aria-hidden="true">·</span>
          <a href={href(path, 'ru')} hreflang="ru" class={lang === 'ru' ? 'text-cyan' : 'text-mute hover:text-fg transition'}>{t(lang, 'lang_ru')}</a>
        </div>
      </div>
      <div>
        <h4 class="eyebrow text-[10px] text-cyan mb-4">{t(lang, 'footer_nav')}</h4>
        <ul class="space-y-3 text-mute text-sm font-light">
          <li><a href={href('/investment')} class="hover:text-fg transition">{t(lang, 'footer_investment')}</a></li>
          <li><a href={href('/process')} class="hover:text-fg transition">{t(lang, 'nav_process')}</a></li>
          <li><a href={href('/projects')} class="hover:text-fg transition">{t(lang, 'nav_projects')}</a></li>
          <li><a href={href('/press')} class="hover:text-fg transition">{t(lang, 'nav_press')}</a></li>
          <li><a href={href('/news')} class="hover:text-fg transition">{t(lang, 'nav_news')}</a></li>
          <li><a href={`${base}guide`} target="_blank" rel="noopener" class="hover:text-fg transition">{t(lang, 'footer_guide')}</a></li>
          <li><a href={`${base}guide-emirates`} target="_blank" rel="noopener" class="hover:text-fg transition">{t(lang, 'footer_guide_emirates')}</a></li>
        </ul>
      </div>
      <div>
        <h4 class="eyebrow text-[10px] text-cyan mb-4">{t(lang, 'footer_contact')}</h4>
        <a href={site.phoneHref} dir="ltr" class="block text-fg text-sm hover:text-cyan transition w-fit">{site.phone}</a>
        <a href={site.whatsapp} target="_blank" rel="noopener" class="flex items-center gap-2 w-fit text-mute text-sm font-light mt-2 hover:text-fg transition"><span set:html={brandIcon('whatsapp', 16)}></span>{t(lang, 'whatsapp')}</a>
        <p class="text-mute text-sm font-light mt-2">{lang === 'ru' ? 'Дубай, ОАЭ' : site.location}</p>
        {social.length > 0 && (
          <div class="flex items-center gap-3 mt-5">
            {social.map((s) => (
              <a href={s.url} target="_blank" rel="noopener" aria-label={s.label} title={s.label} class="glass w-10 h-10 rounded-full flex items-center justify-center text-fg/75 hover:text-cyan hover:border-cyan/50 hover:shadow-[0_0_18px_-4px_rgba(255,210,74,0.5)] transition" set:html={brandIcon(s.name, 20)}></a>
            ))}
          </div>
        )}
      </div>
    </div>
    <div class="border-t border-white/10 mt-10 pt-6 flex flex-col md:flex-row md:rtl:flex-row-reverse justify-between gap-4 text-[10px] text-mute">
      <span class="eyebrow">© {year} Huber Capital · {lang === 'ru' ? 'Гилад Хубер' : site.owner} · {t(lang, 'rights')}</span>
      <div class="flex rtl:flex-row-reverse gap-5">
        <a href={href('/legal/privacy')} class="hover:text-fg transition">{t(lang, 'privacy')}</a>
        <a href={href('/legal/terms')} class="hover:text-fg transition">{t(lang, 'terms')}</a>
        <a href={href('/legal/accessibility')} class="hover:text-fg transition">{t(lang, 'accessibility')}</a>
      </div>
    </div>
    <p class="text-mute/60 text-[10px] font-light leading-relaxed mt-5 text-start max-w-3xl">{t(lang, 'disclaimer')}</p>
  </div>
</footer>
