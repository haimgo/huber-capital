---
const { steps, eyebrow = 'התהליך', heading = 'מאפיון ועד ביצוע' } = Astro.props;
---
<section class="py-24 md:py-32 border-b hair reveal">
  <div class="max-w-container mx-auto px-6 sm:px-8">
    <div class="text-center mb-12 md:mb-16">
      <p class="tracking-[.4em] uppercase text-gold text-[12px] mb-4">{eyebrow}</p>
      <h2 class="font-head text-4xl md:text-5xl">{heading}</h2>
    </div>
    <div class="grid md:grid-cols-4 gap-px bg-[rgba(236,230,218,.15)] border hair">
      {steps.map((s) => (
        <div class="bg-emer p-8 md:p-9 text-right">
          <div class="font-cormorant text-3xl text-gold mb-4">{s.n}</div>
          <h3 class="font-head text-xl mb-3">{s.title}</h3>
          <p class="font-light text-mute text-sm leading-relaxed">{s.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
