---
import { site } from '../data/site.js';
import { brandIcon } from '../lib/icons';
import { t, localizePath, stripLocale, type Lang } from '../lib/i18n';
const { lang = 'he' } = Astro.props as { lang?: Lang };
const base = import.meta.env.BASE_URL.replace(/\/$/, '') + '/';

// Href for a logical path in a given language (adds /ru prefix + base + trailing slash).
const href = (h: string, l: Lang = lang) => {
  const loc = localizePath(h, l);
  if (loc === '/') return base;
  return base + loc.replace(/^\/+/, '') + (loc.endsWith('/') ? '' : '/');
};

const nav = [
  { href: '/', key: 'nav_home' },
  { href: '/investment', key: 'nav_investment' },
  { href: '/process', key: 'nav_process' },
  { href: '/projects', key: 'nav_projects' },
  { href: '/about', key: 'nav_about' },
  { href: '/contact', key: 'nav_contact' },
];

// Current logical path (locale + base stripped) for active state + language switch.
let raw = Astro.url.pathname;
if (base !== '/' && raw.startsWith(base)) raw = '/' + raw.slice(base.length);
const { path: logical0 } = stripLocale(raw);
const path = logical0.replace(/\/+$/, '') || '/';
const isActive = (h: string) => (h === '/' ? path === '/' : path === h || path.startsWith(h + '/'));
const switchHe = href(path, 'he');
const switchRu = href(path, 'ru');
---
<header class="sticky top-0 z-30">
  <div class="max-w-[1200px] mx-auto px-4 sm:px-6 py-4">
    <div class="glass rounded-full px-5 py-3 flex rtl:flex-row-reverse items-center justify-between gap-3">
      <a href={href('/')} class="flex rtl:flex-row-reverse items-center gap-2.5 shrink-0">
        <img src={`${base}assets/logo-mark.png`} alt="Huber Capital" width="132" height="57" class="h-8 w-auto drop-shadow-[0_0_10px_rgba(255,210,74,0.35)]" />
        <span class="eyebrow text-sm neon">HUBER CAPITAL</span>
      </a>
      <nav class="hidden lg:flex flex-row gap-5 xl:gap-7 text-[11px] eyebrow text-mute">
        {nav.map((n) => (
          <a href={href(n.href)} class={`whitespace-nowrap tracking-[0.1em] hover:text-fg transition ${isActive(n.href) ? 'text-cyan' : ''}`}>{t(lang, n.key)}</a>
        ))}
      </nav>
      <div class="flex rtl:flex-row-reverse items-center gap-3">
        <div class="flex items-center gap-1.5 text-[10px] eyebrow" aria-label={t(lang, 'lang_switch')}>
          <a href={switchHe} hreflang="he" class={lang === 'he' ? 'text-cyan' : 'text-mute hover:text-fg transition'}>HE</a>
          <span class="text-mute/40" aria-hidden="true">·</span>
          <a href={switchRu} hreflang="ru" class={lang === 'ru' ? 'text-cyan' : 'text-mute hover:text-fg transition'}>RU</a>
        </div>
        <a href={href('/contact')} class={`btn-neon rounded-full px-5 py-2 text-[11px] eyebrow tracking-[0.1em] whitespace-nowrap text-fg ${lang === 'ru' ? 'hidden xl:inline-block' : 'hidden lg:inline-block'}`}>{t(lang, 'header_cta')}</a>
        <button id="menu-btn" aria-label={lang === 'ru' ? 'Меню' : 'תפריט'} aria-expanded="false" aria-controls="mobile-menu" class="lg:hidden text-cyan">
          <svg width="20" height="14" viewBox="0 0 20 14" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M0 1h20M0 7h20M0 13h20"/></svg>
        </button>
      </div>
    </div>
    <div id="mobile-menu" class="hidden lg:hidden glass rounded-2xl mt-2 px-5 py-2">
      <nav class="flex flex-col text-start text-[12px] eyebrow text-mute">
        {nav.map((n) => (
          <a href={href(n.href)} class={`py-3 border-b border-white/10 hover:text-fg transition ${isActive(n.href) ? 'text-cyan' : ''}`}>{t(lang, n.key)}</a>
        ))}
        <a href={site.whatsapp} target="_blank" rel="noopener" class="py-3 text-cyan flex items-center gap-2"><span set:html={brandIcon('whatsapp', 15)}></span>{t(lang, 'whatsapp')} · {site.phone}</a>
      </nav>
    </div>
  </div>
</header>
