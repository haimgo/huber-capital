---
import { site } from '../data/site.js';

const nav = [
  { href: '/', label: 'בית' },
  { href: '/investment', label: 'השקעה בדובאי' },
  { href: '/process', label: 'התהליך' },
  { href: '/projects', label: 'פרויקטים' },
  { href: '/about', label: 'אודות' },
  { href: '/contact', label: 'צור קשר' },
];
const path = Astro.url.pathname.replace(/\/+$/, '') || '/';
const isActive = (href) => (href === '/' ? path === '/' : path === href || path.startsWith(href + '/'));
---
<header>
  <!-- utility bar -->
  <div class="border-b hair">
    <div class="max-w-container mx-auto px-6 sm:px-8 h-10 flex flex-row-reverse items-center justify-between text-[11px] tracking-[.2em] uppercase text-mute">
      <a href={site.phoneHref} dir="ltr" class="text-ivory hover:text-gold transition">{site.phone}</a>
      <div class="hidden sm:flex flex-row-reverse gap-6">
        <a href={site.whatsapp} class="text-gold hover:opacity-80 transition">וואטסאפ</a>
        <span>עברית</span>
      </div>
    </div>
  </div>

  <!-- main bar -->
  <div class="border-b hair">
    <div class="max-w-container mx-auto px-6 sm:px-8 h-20 md:h-24 flex flex-row-reverse items-center justify-between">
      <a href="/" class="flex flex-row-reverse items-center gap-4">
        <span class="w-11 h-11 border border-gold/50 grid place-items-center font-cormorant text-gold text-lg">HC</span>
        <span class="font-cormorant text-xl md:text-2xl tracking-[.26em] uppercase">Huber Capital</span>
      </a>

      <nav class="hidden md:flex flex-row-reverse gap-7 text-[12px] tracking-[.22em] uppercase text-mute">
        {nav.map((n) => (
          <a href={n.href} class={`hover:text-ivory transition ${isActive(n.href) ? 'text-gold' : ''}`}>{n.label}</a>
        ))}
      </nav>

      <div class="flex flex-row-reverse items-center gap-4">
        <a href="/contact" class="hidden lg:inline-block border border-gold/45 px-5 py-2.5 text-[11px] tracking-[.28em] uppercase hover:bg-gold hover:text-emer transition">שיחת ייעוץ</a>
        <button id="menu-btn" aria-label="פתיחת תפריט" aria-expanded="false" aria-controls="mobile-menu" class="md:hidden w-10 h-10 grid place-items-center border border-gold/40 text-gold">
          <svg width="18" height="12" viewBox="0 0 18 12" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M0 1h18M0 6h18M0 11h18"/></svg>
        </button>
      </div>
    </div>
  </div>

  <!-- mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-b hair bg-panel">
    <nav class="max-w-container mx-auto px-6 py-3 flex flex-col text-right text-[13px] tracking-[.16em] uppercase text-mute">
      {nav.map((n) => (
        <a href={n.href} class={`py-3 border-b hair hover:text-ivory transition ${isActive(n.href) ? 'text-gold' : ''}`}>{n.label}</a>
      ))}
      <a href={site.whatsapp} class="py-3 text-gold">וואטסאפ · {site.phone}</a>
    </nav>
  </div>
</header>
