---
import '../styles/global.css';
import SpaceBackground from '../components/SpaceBackground.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { dirOf, htmlLang, ogLocale, localizePath, stripLocale, t, type Lang } from '../lib/i18n';

const lang: Lang = Astro.locals.lang ?? 'he';
const base = import.meta.env.BASE_URL.replace(/\/$/, '') + '/';

const defaultTitle =
  lang === 'ru'
    ? 'Huber Capital — Хубер Капитал · Инвестиции в недвижимость Дубая'
    : 'Huber Capital — הובר קפיטל · השקעות נדל"ן בדובאי';
const defaultDescription =
  lang === 'ru'
    ? 'Сопровождение израильских инвесторов в недвижимости Дубая — от анализа потребностей до сделки, под ключ.'
    : 'ליווי משקיעים ישראלים בהשקעות נדל"ן בדובאי — מאפיון ועד ביצוע. החל מ-200,000₪ הון עצמי, בליווי מלא A-Z.';

const { title = defaultTitle, description = defaultDescription, ogImage } = Astro.props;

const ogUrl = new URL(ogImage ?? `${base}assets/og.jpg`, Astro.site);
// Locale-aware canonical + hreflang, built from the underlying (locale-stripped) path.
const { path: logicalPath } = stripLocale(Astro.url.pathname);
const canonical = new URL(localizePath(logicalPath, lang), Astro.site);
const heHref = new URL(localizePath(logicalPath, 'he'), Astro.site);
const ruHref = new URL(localizePath(logicalPath, 'ru'), Astro.site);
---
<!DOCTYPE html>
<html lang={htmlLang(lang)} dir={dirOf(lang)}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="he" href={heHref} />
    <link rel="alternate" hreflang="ru" href={ruHref} />
    <link rel="alternate" hreflang="x-default" href={heHref} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogUrl} />
    <meta property="og:locale" content={ogLocale(lang)} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Orbitron:wght@500;700&family=Heebo:wght@300;400;600;800&family=Space+Grotesk:wght@400;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-space text-fg font-body antialiased">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:top-3 focus:right-3 focus:z-50 focus:bg-cyan focus:text-space focus:px-4 focus:py-2 text-[12px]"
      >{t(lang, 'skip')}</a
    >

    <SpaceBackground />

    <div class="relative" style="z-index:2">
      <Header lang={lang} />
      <main id="main">
        <slot />
      </main>
      <Footer lang={lang} />
    </div>

    <script is:inline>
      (function () {
        function reveal() {
          var els = document.querySelectorAll('.reveal');
          if (!('IntersectionObserver' in window)) {
            els.forEach(function (e) { e.classList.add('in'); });
            return;
          }
          var io = new IntersectionObserver(
            function (entries) {
              entries.forEach(function (en) {
                if (en.isIntersecting) {
                  en.target.classList.add('in');
                  io.unobserve(en.target);
                }
              });
            },
            { threshold: 0.12 }
          );
          els.forEach(function (e) { io.observe(e); });
        }
        function menu() {
          var btn = document.getElementById('menu-btn');
          var m = document.getElementById('mobile-menu');
          if (btn && m) {
            btn.addEventListener('click', function () {
              m.classList.toggle('hidden');
              btn.setAttribute('aria-expanded', m.classList.contains('hidden') ? 'false' : 'true');
            });
          }
        }
        if (document.readyState !== 'loading') { reveal(); menu(); }
        else document.addEventListener('DOMContentLoaded', function () { reveal(); menu(); });
      })();
    </script>
  </body>
</html>
