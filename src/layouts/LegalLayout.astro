---
import BaseLayout from './BaseLayout.astro';
const { title, updated = 'יוני 2026' } = Astro.props;
---
<BaseLayout title={`${title} · Huber Capital`} description={title}>
  <section class="border-b hair">
    <div class="max-w-3xl mx-auto px-6 sm:px-8 py-16 md:py-24 text-right">
      <p class="tracking-[.4em] uppercase text-gold text-[12px] mb-4">מסמך</p>
      <h1 class="font-head text-3xl md:text-5xl mb-4">{title}</h1>
      <p class="text-mute text-[12px]">עודכן: {updated}</p>
    </div>
  </section>
  <section class="py-12 md:py-16">
    <div class="max-w-3xl mx-auto px-6 sm:px-8 text-right space-y-5 font-light text-ivory/80 leading-[1.95] [&_h2]:font-head [&_h2]:text-ivory [&_h2]:text-2xl [&_h2]:mt-10 [&_h2]:mb-2 [&_a]:text-gold [&_a]:underline">
      <slot />
    </div>
  </section>
</BaseLayout>
