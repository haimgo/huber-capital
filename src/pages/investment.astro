---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import StatBar from '../components/StatBar.astro';
import CTA from '../components/CTA.astro';
import { stats } from '../data/content.js';

const advantages = [
  'ביקוש עולה ואוכלוסייה בצמיחה',
  'תשואות שכירות גבוהות יחסית',
  'סביבת מיסוי אטרקטיבית למשקיעים',
  'מטבע יציב (דירהם צמוד לדולר)',
  'תשתיות וביטחון ברמה עולמית',
  'נזילות וביקוש בינלאומי',
];
---
<BaseLayout
  title="השקעה בדובאי · Huber Capital"
  description='למה דובאי? אחד משוקי הנדל"ן הצומחים בעולם — יתרונות, נתונים והגישה שלנו ל-26 פרויקטים נבחרים.'
>
  <PageHeader
    eyebrow="השקעה בדובאי"
    title="למה דובאי?"
    sub={'אחד משוקי הנדל"ן הצומחים בעולם — עם יתרונות ייחודיים למשקיע הישראלי.'}
  />

  <section class="py-20 md:py-28 border-b hair reveal">
    <div class="max-w-container mx-auto px-6 sm:px-8 grid md:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div class="text-right">
        <p class="tracking-[.4em] uppercase text-gold text-[12px] mb-5">ההזדמנות</p>
        <h2 class="font-head text-3xl md:text-4xl leading-tight mb-6">שוק בצמיחה, עם יתרונות אמיתיים</h2>
        <div class="w-16 h-px bg-gold/60 mb-7"></div>
        <p class="font-light text-ivory/75 text-lg leading-[1.9] mb-5">דובאי הפכה לאחד ממוקדי ההשקעה המבוקשים בעולם: אוכלוסייה צומחת, ביקוש עולה לשכירות, תשתיות ברמה עולמית וסביבת מיסוי אטרקטיבית למשקיעים.</p>
        <p class="font-light text-ivory/75 text-lg leading-[1.9]">עבור המשקיע הישראלי, השוק מציע שילוב נדיר של פוטנציאל עליית ערך, תשואות שכירות ויציבות — בתנאי שנכנסים אליו עם הפרויקט הנכון, היזם הנכון והנתונים הנכונים.</p>
      </div>
      <ul class="grid sm:grid-cols-2 gap-x-10 gap-y-5 text-right">
        {advantages.map((a) => (
          <li class="flex flex-row-reverse items-start gap-3 border-b hair pb-4">
            <span class="text-gold font-cormorant text-xl leading-none">—</span>
            <span class="font-light text-ivory/85">{a}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <StatBar stats={stats} eyebrow="הנתונים" heading={'שוק הנדל"ן בדובאי במספרים'} />

  <section class="py-20 md:py-28 border-b hair reveal">
    <div class="max-w-3xl mx-auto px-6 sm:px-8 text-center">
      <p class="tracking-[.4em] uppercase text-gold text-[12px] mb-5">הגישה שלנו</p>
      <h2 class="font-head text-3xl md:text-4xl mb-7">גישה ל-26 פרויקטים נבחרים</h2>
      <p class="font-light text-ivory/75 text-lg leading-[1.95]">אנחנו לא עובדים מול "כל פרויקט". אנו בוחנים יזמים, מיקומים ונתונים — ומציעים גישה לפרויקטים נבחרים, לעיתים במחיר מתחת לשוק, דרך צוות מקומי בדובאי. כך מצמצמים סיכון וממקסמים פוטנציאל.</p>
      <p class="text-mute/80 text-[12px] font-light leading-relaxed mt-8">השקעה בנדל"ן בחו"ל כרוכה בסיכון והמידע אינו מהווה ייעוץ השקעות. ראו <a href="/legal/terms" class="text-gold underline">תנאי שימוש</a>.</p>
    </div>
  </section>

  <CTA
    title={`רוצים לבחון אם דובאי<br/>מתאימה לכם?`}
    sub="נתחיל בשיחת אפיון קצרה — ללא התחייבות."
  />
</BaseLayout>
