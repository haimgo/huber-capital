---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import CTA from '../../components/CTA.astro';
import { serverClient } from '../../lib/supabase';
import { getNews } from '../../lib/content';
const sb = serverClient(Astro.cookies);
const news = await getNews(sb, { publishedOnly: true });
const base = import.meta.env.BASE_URL.replace(/\/$/, '') + '/';
---
<BaseLayout title="חדשות · Huber Capital" description="עדכונים וכתבות מהובר קפיטל.">
  <PageHeader eyebrow="NEWS" title="חדשות ועדכונים" sub="מהנעשה בשוק ובמשרד." />
  <section class="px-6 pb-16 md:pb-24">
    <div class="max-w-container mx-auto">
      {news.length === 0 ? (
        <p class="text-mute text-center">אין כתבות עדיין.</p>
      ) : (
        <div class="grid md:grid-cols-3 gap-6">
          {news.map((n) => (
            <a href={`${base}news/${n.slug}/`} class="glass rounded-3xl overflow-hidden block hover:border-cyan/40 transition text-right">
              {n.cover_url && <img src={n.cover_url} alt={n.title} class="w-full h-44 object-cover" />}
              <div class="p-6">
                <span class="eyebrow text-[10px] text-cyan">{n.date}</span>
                <h3 class="font-display font-semibold text-xl mt-2 mb-2">{n.title}</h3>
                <p class="text-mute text-sm font-light">{n.excerpt}</p>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
  <CTA title="רוצים לשמוע עוד?" sub="דברו איתנו לשיחת אפיון." />
</BaseLayout>
