---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import CTA from '../../components/CTA.astro';
import { serverClient } from '../../lib/supabase';
import { getNews } from '../../lib/content';
import { byLang, localizePath, type Lang } from '../../lib/i18n';

const lang: Lang = Astro.locals.lang ?? 'he';
const base = import.meta.env.BASE_URL.replace(/\/$/, '') + '/';
const sb = serverClient(Astro.cookies);
const newsR = await getNews(sb, { publishedOnly: true });
const news = newsR.map((n: any) => ({ ...n, title: byLang(n, 'title', lang), excerpt: byLang(n, 'excerpt', lang) }));
const newsHref = (slug: string) => base + localizePath(`/news/${slug}`, lang).replace(/^\/+/, '') + '/';

const tr = {
  he: { title: 'חדשות · Huber Capital', desc: 'עדכונים וכתבות מהובר קפיטל.', h: 'חדשות ועדכונים', sub: 'מהנעשה בשוק ובמשרד.', empty: 'אין כתבות עדיין.', ctaT: 'רוצים לשמוע עוד?', ctaS: 'דברו איתנו לשיחת אפיון.' },
  ru: { title: 'Новости · Huber Capital', desc: 'Обновления и публикации Huber Capital.', h: 'Новости и обновления', sub: 'О том, что происходит на рынке и в офисе.', empty: 'Пока нет публикаций.', ctaT: 'Хотите узнать больше?', ctaS: 'Свяжитесь с нами для консультации.' },
}[lang];
---
<BaseLayout title={tr.title} description={tr.desc}>
  <PageHeader eyebrow="NEWS" title={tr.h} sub={tr.sub} />
  <section class="px-6 pb-16 md:pb-24">
    <div class="max-w-[1200px] mx-auto">
      {news.length === 0 ? (
        <p class="text-mute text-center">{tr.empty}</p>
      ) : (
        <div class="grid md:grid-cols-3 gap-6">
          {news.map((n) => (
            <a href={newsHref(n.slug)} class="glass rounded-3xl overflow-hidden block hover:border-cyan/40 transition text-start">
              {n.cover_url && <img src={n.cover_url} alt={n.title} class="w-full h-44 object-cover" />}
              <div class="p-6">
                <span class="eyebrow text-[10px] text-cyan">{n.date}</span>
                <h3 class="font-display font-semibold text-xl mt-2 mb-2">{n.title}</h3>
                <p class="text-mute text-sm font-light">{n.excerpt}</p>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
  <CTA lang={lang} title={tr.ctaT} sub={tr.ctaS} />
</BaseLayout>
