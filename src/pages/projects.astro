---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import CTA from '../components/CTA.astro';
import { serverClient } from '../lib/supabase';
import { getAreas, getSections } from '../lib/content';
import { pageText } from '../lib/pageSections';
const sb = serverClient(Astro.cookies);
const [areas, sec] = await Promise.all([getAreas(sb), getSections(sb, 'projects')]);
const t = (s: string) => pageText(sec, 'projects', s);

const approach = [
  { n: '01', title: 'בחירה קפדנית', text: 'כל פרויקט נבחן לפי היזם, המיקום, התמחור והפוטנציאל — רק הטובים נכנסים לרשימה.' },
  { n: '02', title: 'מחיר מתחת לשוק', text: 'גישה להזדמנויות ולתמחור מועדף דרך קשרים ישירים מול יזמים.' },
  { n: '03', title: 'צוות מקומי בדובאי', text: 'נוכחות מקומית שמכירה את השוק, את היזמים ואת השטח — לא מרחוק.' },
];
---
<BaseLayout
  title="פרויקטים ואזורים · Huber Capital"
  description="26 פרויקטים נבחרים וגישה למחיר מתחת לשוק, באזורי ההשקעה המובילים בדובאי."
>
  <PageHeader
    eyebrow={t('header_eyebrow')}
    title={t('header_title')}
    sub={t('header_sub')}
  />

  <section class="px-6 py-16 md:py-24 reveal">
    <div class="max-w-container mx-auto">
      <div class="grid md:grid-cols-3 gap-6">
        {approach.map((a) => (
          <div class="glass rounded-3xl p-8 md:p-9 text-right">
            <div class="font-display font-extrabold text-4xl neon glow mb-5">{a.n}</div>
            <h3 class="font-display font-semibold text-2xl mb-3">{a.title}</h3>
            <p class="font-light text-mute leading-relaxed">{a.text}</p>
          </div>
        ))}
      </div>
      <p class="text-center font-light text-fg/75 text-lg mt-12 max-w-2xl mx-auto">{t('note')}</p>
    </div>
  </section>

  <section class="px-6 py-16 md:py-24 reveal">
    <div class="max-w-container mx-auto">
      <div class="text-center mb-12 md:mb-16">
        <p class="eyebrow text-cyan text-[11px] mb-4">{t('areas_eyebrow')}</p>
        <h2 class="font-display font-bold text-4xl md:text-5xl">{t('areas_heading')}</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {areas.map((a) => (
          <div class="glass rounded-3xl p-8 text-right">
            <span class="eyebrow text-[10px] text-cyan">{a.name}</span>
            <h3 class="font-display font-semibold text-2xl mt-2 mb-3">{a.he}</h3>
            <p class="font-light text-mute leading-relaxed text-sm">{a.blurb}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA
    title={t('cta_title')}
    sub={t('cta_sub')}
  />
</BaseLayout>
