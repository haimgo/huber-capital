---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import CTA from '../components/CTA.astro';
import { serverClient } from '../lib/supabase';
import { getAreas, getSections } from '../lib/content';
import { pageText } from '../lib/pageSections';
import { byLang, type Lang } from '../lib/i18n';
import { icon } from '../lib/icons';

const lang: Lang = Astro.locals.lang ?? 'he';
const sb = serverClient(Astro.cookies);
const [areasR, sec] = await Promise.all([getAreas(sb), getSections(sb, 'projects')]);
const t = (s: string) => pageText(sec, 'projects', s, lang);
// name = English (shared eyebrow); display = Russian column or Hebrew name; blurb localized.
const areas = areasR.map((a: any) => ({
  name: a.name,
  display: lang === 'ru' && a.ru && String(a.ru).trim() ? a.ru : a.he,
  blurb: byLang(a, 'blurb', lang),
}));

const approachByLang = {
  he: [
    { n: '01', title: 'בחירה קפדנית', text: 'כל פרויקט נבחן לפי היזם, המיקום, התמחור והפוטנציאל — רק הטובים נכנסים לרשימה.' },
    { n: '02', title: 'מחיר מתחת לשוק', text: 'גישה להזדמנויות ולתמחור מועדף דרך קשרים ישירים מול יזמים.' },
    { n: '03', title: 'צוות מקומי בדובאי', text: 'נוכחות מקומית שמכירה את השוק, את היזמים ואת השטח — לא מרחוק.' },
  ],
  ru: [
    { n: '01', title: 'Тщательный отбор', text: 'Каждый проект оценивается по застройщику, локации, цене и потенциалу — в список попадают только лучшие.' },
    { n: '02', title: 'Цена ниже рынка', text: 'Доступ к возможностям и льготным ценам через прямые связи с застройщиками.' },
    { n: '03', title: 'Локальная команда в Дубае', text: 'Местное присутствие, знающее рынок, застройщиков и объекты — не на расстоянии.' },
  ],
};
const approach = approachByLang[lang];
const approachIcons = ['filter', 'tag', 'pin'];
const meta = {
  he: { title: 'פרויקטים ואזורים · Huber Capital', description: '26 פרויקטים נבחרים וגישה למחיר מתחת לשוק, באזורי ההשקעה המובילים בדובאי.' },
  ru: { title: 'Проекты и районы · Huber Capital', description: '26 отобранных проектов и доступ к цене ниже рынка в ведущих инвестиционных районах Дубая.' },
}[lang];
---
<BaseLayout title={meta.title} description={meta.description}>
  <PageHeader eyebrow={t('header_eyebrow')} title={t('header_title')} sub={t('header_sub')} />

  <section class="px-6 py-16 md:py-24 reveal">
    <div class="max-w-container mx-auto">
      <div class="grid md:grid-cols-3 gap-6">
        {approach.map((a, i) => (
          <div class="glass rounded-3xl p-8 md:p-9 text-start transition duration-300 hover:border-cyan/40 hover:shadow-[0_0_30px_-6px_rgba(255,210,74,0.28)]">
            <div class="flex items-start justify-between mb-5">
              <span class="font-display font-extrabold text-4xl neon glow leading-none">{a.n}</span>
              <span class="text-cyan/70 shrink-0 mt-1" set:html={icon(approachIcons[i % approachIcons.length])}></span>
            </div>
            <h3 class="font-display font-semibold text-2xl mb-3">{a.title}</h3>
            <p class="font-light text-mute leading-relaxed">{a.text}</p>
          </div>
        ))}
      </div>
      <p class="text-center font-light text-fg/75 text-lg mt-12 max-w-2xl mx-auto">{t('note')}</p>
    </div>
  </section>

  <section class="px-6 py-16 md:py-24 reveal">
    <div class="max-w-container mx-auto">
      <div class="text-center mb-12 md:mb-16">
        <p class="eyebrow text-cyan text-[11px] mb-4">{t('areas_eyebrow')}</p>
        <h2 class="font-display font-bold text-4xl md:text-5xl">{t('areas_heading')}</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {areas.map((a) => (
          <div class="glass rounded-3xl p-8 text-start transition duration-300 hover:border-cyan/40 hover:shadow-[0_0_30px_-6px_rgba(255,210,74,0.28)]">
            <div class="flex items-center justify-between mb-2">
              <span class="eyebrow text-[10px] text-cyan">{a.name}</span>
              <span class="text-cyan/60 shrink-0" set:html={icon('pin', 22)}></span>
            </div>
            <h3 class="font-display font-semibold text-2xl mb-3">{a.display}</h3>
            <p class="font-light text-mute leading-relaxed text-sm">{a.blurb}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA lang={lang} title={t('cta_title')} sub={t('cta_sub')} />
</BaseLayout>
