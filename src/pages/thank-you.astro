---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site.js';
---
<BaseLayout title="תודה · Huber Capital" description="קיבלנו את פנייתכם — ניצור קשר בהקדם.">
  <section class="min-h-[62vh] flex items-center justify-center text-center py-24 md:py-28 border-b hair">
    <div class="max-w-xl px-6">
      <p class="tracking-[.4em] uppercase text-gold text-[12px] mb-6">תודה</p>
      <h1 class="font-head text-4xl md:text-6xl mb-6">קיבלנו את פנייתכם</h1>
      <p class="font-light text-ivory/75 text-lg leading-relaxed mb-10">ניצור איתכם קשר בהקדם לתיאום שיחת אפיון. לפנייה מיידית ניתן לחייג או לכתוב לנו בוואטסאפ.</p>
      <div class="flex flex-col sm:flex-row-reverse gap-6 justify-center items-center">
        <a href={site.phoneHref} dir="ltr" class="border border-gold/50 px-10 py-4 text-[11px] tracking-[.3em] uppercase hover:bg-gold hover:text-emer transition duration-300">{site.phone}</a>
        <a href={site.whatsapp} class="text-[11px] tracking-[.3em] uppercase text-ivory/85 border-b border-gold/40 pb-1.5 hover:text-gold transition">וואטסאפ</a>
      </div>
      <a href="/" class="inline-block mt-10 text-[11px] tracking-[.3em] uppercase text-mute hover:text-gold transition">חזרה לדף הבית</a>
    </div>
  </section>
</BaseLayout>
