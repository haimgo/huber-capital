---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site.js';
---
<BaseLayout title="תודה · Huber Capital" description="קיבלנו את פנייתכם — ניצור קשר בהקדם.">
  <section class="min-h-[70vh] flex items-center justify-center text-center px-6 py-24">
    <div class="max-w-xl">
      <p class="eyebrow text-[11px] mb-6" style="color:#7fe9ff;">THANK YOU</p>
      <h1 class="font-display font-bold text-4xl md:text-6xl mb-6 neon glow">קיבלנו את פנייתכם</h1>
      <p class="font-light text-mute text-lg leading-relaxed mb-10">ניצור איתכם קשר בהקדם לתיאום שיחת אפיון. לפנייה מיידית ניתן לחייג או לכתוב לנו בוואטסאפ.</p>
      <div class="flex flex-col sm:flex-row-reverse gap-5 justify-center items-center">
        <a href={site.phoneHref} dir="ltr" class="btn-neon rounded-full px-10 py-4 eyebrow text-sm text-fg">{site.phone}</a>
        <a href={site.whatsapp} class="glass rounded-full px-10 py-4 eyebrow text-sm text-fg/80">וואטסאפ</a>
      </div>
      <a href="/" class="inline-block mt-10 eyebrow text-[10px] text-mute hover:text-cyan transition">חזרה לדף הבית</a>
    </div>
  </section>
</BaseLayout>
