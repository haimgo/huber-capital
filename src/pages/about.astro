---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import AboutGilad from '../components/AboutGilad.astro';
import CTA from '../components/CTA.astro';
import { serverClient } from '../lib/supabase';
import { getSettings, getSections } from '../lib/content';
import { pageText } from '../lib/pageSections';
import type { Lang } from '../lib/i18n';
import { icon } from '../lib/icons';

const lang: Lang = Astro.locals.lang ?? 'he';
const sb = serverClient(Astro.cookies);
const [settings, sec] = await Promise.all([getSettings(sb), getSections(sb, 'about')]);
const t = (s: string) => pageText(sec, 'about', s, lang);

const valuesByLang = {
  he: [
    { title: 'המשקיע לפני הכל', text: 'אני בוחן השקעות, לא מוכר נכסים. ההמלצה נקבעת לפי האינטרס שלכם בלבד.' },
    { title: 'דיסקרטיות מלאה', text: 'כל תהליך נשמר אישי וחסוי, מהשיחה הראשונה ועד הביצוע.' },
    { title: 'צוות מקומי בדובאי', text: 'נוכחות מקומית שמכירה את היזמים, את השוק ואת השטח.' },
    { title: 'שקיפות בנתונים', text: 'החלטות מבוססות על נתונים מדויקים — לא על הבטחות.' },
  ],
  ru: [
    { title: 'Инвестор прежде всего', text: 'Я анализирую инвестиции, а не продаю недвижимость. Рекомендация определяется только вашими интересами.' },
    { title: 'Полная конфиденциальность', text: 'Весь процесс остаётся личным и конфиденциальным — от первого разговора до сделки.' },
    { title: 'Локальная команда в Дубае', text: 'Местное присутствие, знающее застройщиков, рынок и объекты на месте.' },
    { title: 'Прозрачность данных', text: 'Решения основаны на точных данных, а не на обещаниях.' },
  ],
};
const values = valuesByLang[lang];
const valueIcons = ['heart', 'lock', 'users', 'eye'];
const meta = {
  he: { title: 'אודות · גלעד הובר · Huber Capital', description: 'גלעד הובר — 30 שנות ניסיון עסקי, בית בדובאי, וגישה שמתחילה ונגמרת באינטרס של המשקיע.' },
  ru: { title: 'О нас · Гилад Хубер · Huber Capital', description: 'Гилад Хубер — 30 лет опыта в бизнесе, дом в Дубае и подход, основанный на интересах инвестора.' },
}[lang];
---
<BaseLayout title={meta.title} description={meta.description}>
  <PageHeader eyebrow={t('header_eyebrow')} title={t('header_title')} sub={t('header_sub')} />

  <AboutGilad showLink={false} image={settings?.gilad_image || '/assets/gilad.jpg'} lang={lang} />

  <section class="px-6 py-16 md:py-24 reveal">
    <div class="max-w-[1200px] mx-auto">
      <div class="text-center mb-12 md:mb-16">
        <p class="eyebrow text-cyan text-[11px] mb-4">{t('values_eyebrow')}</p>
        <h2 class="font-display font-bold text-4xl md:text-5xl">{t('values_heading')}</h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-6">
        {values.map((v, i) => (
          <div class="glass rounded-3xl p-8 md:p-9 text-start transition duration-300 hover:border-cyan/40 hover:shadow-[0_0_30px_-6px_rgba(255,210,74,0.28)]">
            <span class="text-cyan/70 inline-block mb-4" set:html={icon(valueIcons[i % valueIcons.length])}></span>
            <h3 class="font-display font-semibold text-2xl mb-3">{v.title}</h3>
            <p class="font-light text-mute leading-relaxed">{v.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA lang={lang} title={t('cta_title')} sub={t('cta_sub')} />
</BaseLayout>
