---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import AboutGilad from '../components/AboutGilad.astro';
import CTA from '../components/CTA.astro';
import { serverClient } from '../lib/supabase';
import { getSettings, getSections } from '../lib/content';
import { pageText } from '../lib/pageSections';
const sb = serverClient(Astro.cookies);
const [settings, sec] = await Promise.all([getSettings(sb), getSections(sb, 'about')]);
const t = (s: string) => pageText(sec, 'about', s);

const values = [
  { title: 'המשקיע לפני הכל', text: 'אני בוחן השקעות, לא מוכר נכסים. ההמלצה נקבעת לפי האינטרס שלכם בלבד.' },
  { title: 'דיסקרטיות מלאה', text: 'כל תהליך נשמר אישי וחסוי, מהשיחה הראשונה ועד הביצוע.' },
  { title: 'צוות מקומי בדובאי', text: 'נוכחות מקומית שמכירה את היזמים, את השוק ואת השטח.' },
  { title: 'שקיפות בנתונים', text: 'החלטות מבוססות על נתונים מדויקים — לא על הבטחות.' },
];
---
<BaseLayout
  title="אודות · גלעד הובר · Huber Capital"
  description="גלעד הובר — 30 שנות ניסיון עסקי, בית בדובאי, וגישה שמתחילה ונגמרת באינטרס של המשקיע."
>
  <PageHeader
    eyebrow={t('header_eyebrow')}
    title={t('header_title')}
    sub={t('header_sub')}
  />

  <AboutGilad showLink={false} image={settings?.gilad_image} />

  <section class="px-6 py-16 md:py-24 reveal">
    <div class="max-w-container mx-auto">
      <div class="text-center mb-12 md:mb-16">
        <p class="eyebrow text-cyan text-[11px] mb-4">{t('values_eyebrow')}</p>
        <h2 class="font-display font-bold text-4xl md:text-5xl">{t('values_heading')}</h2>
      </div>
      <div class="grid sm:grid-cols-2 gap-6">
        {values.map((v) => (
          <div class="glass rounded-3xl p-8 md:p-9 text-right">
            <h3 class="font-display font-semibold text-2xl mb-3">{v.title}</h3>
            <p class="font-light text-mute leading-relaxed">{v.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA
    title={t('cta_title')}
    sub={t('cta_sub')}
  />
</BaseLayout>
