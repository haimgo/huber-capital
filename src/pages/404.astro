---
import BaseLayout from '../layouts/BaseLayout.astro';
import { localizePath, type Lang } from '../lib/i18n';
const lang: Lang = Astro.locals.lang ?? 'he';
const base = import.meta.env.BASE_URL.replace(/\/$/, '') + '/';
const homeHref = base + localizePath('/', lang).replace(/^\/+/, '');
const tr = {
  he: { title: 'הדף לא נמצא · Huber Capital', desc: 'הדף שחיפשתם לא נמצא.', h: 'הדף לא נמצא', sub: 'ייתכן שהקישור שגוי או שהדף הוסר. נשמח להחזיר אתכם הביתה.', back: 'חזרה לדף הבית' },
  ru: { title: 'Страница не найдена · Huber Capital', desc: 'Запрошенная страница не найдена.', h: 'Страница не найдена', sub: 'Возможно, ссылка неверна или страница была удалена. Вернём вас на главную.', back: 'На главную' },
}[lang];
---
<BaseLayout title={tr.title} description={tr.desc}>
  <section class="min-h-[70vh] flex items-center justify-center text-center px-6 py-24">
    <div class="max-w-lg">
      <p class="font-display font-extrabold text-7xl md:text-8xl neon glow mb-4">404</p>
      <h1 class="font-display font-bold text-3xl md:text-5xl mb-6">{tr.h}</h1>
      <p class="font-light text-mute text-lg mb-10">{tr.sub}</p>
      <a href={homeHref} class="btn-neon rounded-full px-10 py-4 eyebrow text-sm text-fg inline-block">{tr.back}</a>
    </div>
  </section>
</BaseLayout>
