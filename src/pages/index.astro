---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import StatBar from '../components/StatBar.astro';
import MistakeCards from '../components/MistakeCards.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import AboutGilad from '../components/AboutGilad.astro';
import PressCards from '../components/PressCards.astro';
import CTA from '../components/CTA.astro';
import ApproachBanner from '../components/ApproachBanner.astro';
import { serverClient } from '../lib/supabase';
import { getStats, getMistakes, getSteps, getPress, getSettings, getSections } from '../lib/content';
import { byLang, t, type Lang } from '../lib/i18n';
import { pageText } from '../lib/pageSections';

const lang: Lang = Astro.locals.lang ?? 'he';
const sb = serverClient(Astro.cookies);
const [statsR, mistakesR, processR, pressR, s, sec] = await Promise.all([
  getStats(sb), getMistakes(sb), getSteps(sb), getPress(sb), getSettings(sb), getSections(sb, 'home'),
]);
const ta = (slot: string) => pageText(sec, 'home', slot, lang);

// Localize Supabase rows for the active language (ru → *_ru, fall back to Hebrew).
const stats = statsR.map((r: any) => ({ ...r, value: byLang(r, 'value', lang), label: byLang(r, 'label', lang) }));
const mistakes = mistakesR.map((r: any) => ({ ...r, title: byLang(r, 'title', lang), text: byLang(r, 'text', lang) }));
const process = processR.map((r: any) => ({ ...r, title: byLang(r, 'title', lang), text: byLang(r, 'text', lang) }));
const press = pressR.map((r: any) => ({ ...r, title: byLang(r, 'title', lang) }));

// Settings text by language: ru → DB *_ru → Russian default; he → DB → Hebrew default.
const cxt = (field: string, he: string, ru: string): string => {
  if (lang === 'ru') {
    const v = s?.[`${field}_ru`];
    return v && String(v).trim() ? v : ru;
  }
  return s?.[field] || he;
};

const heroEyebrow = cxt('hero_eyebrow', 'DUBAI · NEXT-GEN REAL ESTATE', 'DUBAI · NEXT-GEN REAL ESTATE');
const heroTitle = cxt('hero_title', 'השקעה בדובאי', 'Инвестиции в Дубае');
const heroSub = cxt('hero_sub', 'החל מ-200,000₪ הון עצמי · פוטנציאל עליית ערך של כ-10% בשנה · ליווי מלא A-Z', 'От 200 000 ₪ собственного капитала · потенциал роста стоимости ~10% в год · полное сопровождение A–Z');
const manifMain = cxt('manifesto_main', 'אני לא מוכר נכסים — אני בוחן השקעות.', 'Я не продаю недвижимость — я анализирую инвестиции.');
const manifSub = cxt('manifesto_sub', 'זו לא עוד עסקה. זה מסע שמטרתו לייצר עבורך הצלחה.', 'Это не просто сделка. Это путь, цель которого — создать для вас успех.');
const ctaTitle = cxt('cta_title', 'מוכנים לצאת למסע?', 'Готовы отправиться в путь?');
const ctaSub = cxt('cta_sub', 'שיחת אפיון ראשונית, ללא התחייבות — נבין יחד מה נכון עבורכם.', 'Первичная консультация без обязательств — вместе поймём, что подходит именно вам.');
---
<BaseLayout>
  <Hero lang={lang} eyebrow={heroEyebrow} title={heroTitle} sub={heroSub} />

  <!-- Manifesto -->
  <section class="px-6 py-20 md:py-28 text-center reveal">
    <div class="max-w-4xl mx-auto">
      <p class="font-display font-bold text-3xl md:text-5xl leading-tight neon glow">{manifMain}</p>
      <p class="text-mute font-light mt-6 text-lg">{manifSub}</p>
    </div>
  </section>

  <StatBar stats={stats} eyebrow={t(lang, 'home_stat_eyebrow')} heading={t(lang, 'home_stat_heading')} />
  <MistakeCards mistakes={mistakes} eyebrow={t(lang, 'mistakes_eyebrow')} heading={t(lang, 'mistakes_heading')} closing={t(lang, 'mistakes_closing')} />
  <ProcessSteps steps={process} eyebrow={t(lang, 'process_eyebrow')} heading={t(lang, 'process_heading')} />
  <ApproachBanner title={ta('approach_title')} line1={ta('approach_line1')} line2={ta('approach_line2')} body={ta('approach_body')} />
  <AboutGilad lang={lang} image={s?.gilad_image || '/assets/gilad.jpg'} />
  <PressCards press={press} lang={lang} eyebrow={t(lang, 'press_eyebrow')} heading={t(lang, 'press_heading')} />
  <CTA lang={lang} title={ctaTitle} sub={ctaSub} />
</BaseLayout>
