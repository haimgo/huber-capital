---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import StatBar from '../components/StatBar.astro';
import MistakeCards from '../components/MistakeCards.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import AboutGilad from '../components/AboutGilad.astro';
import PressCards from '../components/PressCards.astro';
import CTA from '../components/CTA.astro';
import { serverClient } from '../lib/supabase';
import { getStats, getMistakes, getSteps, getPress, getSettings } from '../lib/content';

const sb = serverClient(Astro.cookies);
const [stats, mistakes, process, press, s] = await Promise.all([
  getStats(sb), getMistakes(sb), getSteps(sb), getPress(sb), getSettings(sb),
]);
---
<BaseLayout>
  <Hero
    eyebrow={s?.hero_eyebrow ?? 'DUBAI · NEXT-GEN REAL ESTATE'}
    title={s?.hero_title ?? 'השקעה בדובאי'}
    sub={s?.hero_sub ?? 'החל מ-200,000₪ הון עצמי · פוטנציאל עליית ערך של כ-10% בשנה · ליווי מלא A-Z'}
  />

  <!-- Manifesto -->
  <section class="px-6 py-20 md:py-28 text-center reveal">
    <div class="max-w-4xl mx-auto">
      <p class="font-display font-bold text-3xl md:text-5xl leading-tight neon glow">{s?.manifesto_main ?? 'אני לא מוכר נכסים — אני בוחן השקעות.'}</p>
      <p class="text-mute font-light mt-6 text-lg">{s?.manifesto_sub ?? 'זו לא עוד עסקה. זה מסע שמטרתו לייצר עבורך הצלחה.'}</p>
    </div>
  </section>

  <StatBar stats={stats} eyebrow="ההזדמנות" heading={'שוק הנדל"ן בדובאי בצמיחה מתמדת'} />
  <MistakeCards mistakes={mistakes} />
  <ProcessSteps steps={process} />
  <AboutGilad image={s?.gilad_image} />
  <PressCards press={press} />
  <CTA
    title={s?.cta_title ?? 'מוכנים לצאת למסע?'}
    sub={s?.cta_sub ?? 'שיחת אפיון ראשונית, ללא התחייבות — נבין יחד מה נכון עבורכם.'}
  />
</BaseLayout>
