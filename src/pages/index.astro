---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import StatBar from '../components/StatBar.astro';
import MistakeCards from '../components/MistakeCards.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import AboutGilad from '../components/AboutGilad.astro';
import PressCards from '../components/PressCards.astro';
import CTA from '../components/CTA.astro';
import { stats, mistakes, process, press } from '../data/content.js';
---
<BaseLayout>
  <Hero
    eyebrow="DUBAI · NEXT-GEN REAL ESTATE"
    title="השקעה בדובאי"
    sub="החל מ-200,000₪ הון עצמי · פוטנציאל עליית ערך של כ-10% בשנה · ליווי מלא A-Z"
  />

  <!-- Manifesto -->
  <section class="px-6 py-20 md:py-28 text-center reveal">
    <div class="max-w-4xl mx-auto">
      <p class="font-display font-bold text-3xl md:text-5xl leading-tight">אני לא מוכר נכסים — <span class="neon glow">אני בוחן השקעות.</span></p>
      <p class="text-mute font-light mt-6 text-lg">זו לא עוד עסקה. זה מסע שמטרתו לייצר עבורך הצלחה.</p>
    </div>
  </section>

  <StatBar stats={stats} eyebrow="ההזדמנות" heading={'שוק הנדל"ן בדובאי בצמיחה מתמדת'} />
  <MistakeCards mistakes={mistakes} />
  <ProcessSteps steps={process} />
  <AboutGilad />
  <PressCards press={press} />
  <CTA
    title="מוכנים לצאת למסע?"
    sub="שיחת אפיון ראשונית, ללא התחייבות — נבין יחד מה נכון עבורכם."
  />
</BaseLayout>
