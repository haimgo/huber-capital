---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import CTA from '../components/CTA.astro';
import { process } from '../data/content.js';

const includes = [
  'אפיון צרכים ובניית אסטרטגיית השקעה אישית',
  'בחירת פרויקט מתוך 26 פרויקטים נבחרים',
  'בדיקת נאותות משפטית, פיננסית ותכנונית מול היזם',
  'ליווי ברכישה, במימון ובחתימת ההסכמים',
  'ליווי לאחר המסירה — ניהול, השכרה ואסטרטגיית יציאה',
];
---
<BaseLayout
  title="התהליך · Huber Capital"
  description="תהליך מדויק של בחירה, בדיקה וביצוע — מאפיון הצרכים ועד מסירת המפתח וגם אחריה."
>
  <PageHeader
    eyebrow="THE PROCESS"
    title="מאפיון ועד ביצוע"
    sub="תהליך מדויק שמתחיל ונגמר באינטרס שלכם — בחירה, בדיקה וביצוע."
  />

  <ProcessSteps steps={process} eyebrow="ארבעה שלבים" heading="איך זה עובד" />

  <section class="px-6 py-16 md:py-24 reveal">
    <div class="max-w-3xl mx-auto glass rounded-[28px] p-10 md:p-14 text-right">
      <p class="eyebrow text-cyan text-[11px] mb-5 text-center">הליווי המלא</p>
      <h2 class="font-display font-bold text-3xl md:text-4xl mb-10 text-center">מה כולל הליווי</h2>
      <ul class="space-y-5">
        {includes.map((item, i) => (
          <li class="flex flex-row-reverse items-start gap-4 border-b border-white/10 pb-5">
            <span class="font-display font-extrabold text-2xl neon leading-none shrink-0">{String(i + 1).padStart(2, '0')}</span>
            <span class="font-light text-fg/85 text-lg leading-relaxed">{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <CTA
    title="מוכנים להתחיל בשלב הראשון?"
    sub="שיחת אפיון ראשונית — נבין את התקציב, המטרות ורמת הסיכון."
  />
</BaseLayout>
