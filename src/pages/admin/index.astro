---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { serverClient } from '../../lib/supabase';

const sb = serverClient(Astro.cookies);

const count = async (table: string) => {
  const { count } = await sb.from(table).select('*', { count: 'exact', head: true });
  return count ?? 0;
};

const [stats, process, mistakes, areas, press, newsTotal, newsPub, admins] = await Promise.all([
  count('stats'),
  count('process_steps'),
  count('mistakes'),
  count('areas'),
  count('press'),
  count('news'),
  sb.from('news').select('*', { count: 'exact', head: true }).eq('published', true).then((r) => r.count ?? 0),
  count('admins'),
]);
const listsTotal = stats + process + mistakes + areas + press;

let mediaCount = 0;
try {
  const { data } = await sb.storage.from('media').list('', { limit: 100 });
  mediaCount = (data ?? []).filter((f) => f.name !== '.emptyFolderPlaceholder').length;
} catch {}

// Inline Lucide icon paths (stroke = currentColor), one per dashboard section.
const icons = {
  settings: '<line x1="21" y1="4" x2="14" y2="4"/><line x1="10" y1="4" x2="3" y2="4"/><line x1="21" y1="12" x2="12" y2="12"/><line x1="8" y1="12" x2="3" y2="12"/><line x1="21" y1="20" x2="16" y2="20"/><line x1="12" y1="20" x2="3" y2="20"/><line x1="14" y1="2" x2="14" y2="6"/><line x1="8" y1="10" x2="8" y2="14"/><line x1="16" y1="18" x2="16" y2="22"/>',
  lists: '<line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/>',
  pages: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/>',
  news: '<path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/><path d="M18 14h-8"/><path d="M15 18h-5"/><path d="M10 6h8v4h-8V6Z"/>',
  media: '<rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>',
  admins: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
};

const cards = [
  { href: '/admin/settings', t: 'הגדרות אתר', d: 'כותרות הירו, מנשר, קריאה לפעולה', meta: '', view: '/', icon: icons.settings },
  { href: '/admin/lists/stats', t: 'רשימות תוכן', d: 'נתונים, תהליך, טעויות, אזורים, תקשורת', meta: `${listsTotal} פריטים`, icon: icons.lists },
  { href: '/admin/pages', t: 'טקסטים בעמודים', d: 'כותרות ופסקאות לעמודים', meta: '', icon: icons.pages },
  { href: '/admin/news', t: 'חדשות', d: 'כתבות ועדכונים', meta: `${newsTotal} כתבות · ${newsPub} מפורסמות`, view: '/news', icon: icons.news },
  { href: '/admin/media', t: 'מדיה', d: 'תמונות', meta: `${mediaCount} תמונות`, icon: icons.media },
  { href: '/admin/admins', t: 'מנהלים', d: 'הוספה והסרה של מנהלים', meta: `${admins} מנהלים`, icon: icons.admins },
];
---
<AdminLayout title="לוח בקרה">
  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
    {cards.map((c) => (
      <div class="glass rounded-2xl p-6 text-start hover:border-cyan/40 transition relative">
        <a href={c.href} class="absolute inset-0 rounded-2xl" aria-label={c.t}></a>
        <div class="flex items-start justify-between gap-3 mb-2">
          <div class="flex items-center gap-3 min-w-0">
            <span class="shrink-0 grid place-items-center w-10 h-10 rounded-xl bg-cyan/10 text-cyan border border-cyan/20">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={c.icon}></svg>
            </span>
            <h2 class="font-display font-semibold text-xl truncate">{c.t}</h2>
          </div>
          {c.meta && (
            <span class="eyebrow text-[10px] text-cyan/90 bg-cyan/10 rounded-full px-2.5 py-1 shrink-0 whitespace-nowrap mt-1.5">{c.meta}</span>
          )}
        </div>
        <p class="text-mute text-sm font-light">{c.d}</p>
        {c.view && (
          <a href={c.view} target="_blank" rel="noopener" class="relative z-10 inline-block mt-3 eyebrow text-[10px] text-mute hover:text-cyan transition">צפייה באתר ↗</a>
        )}
      </div>
    ))}
  </div>
</AdminLayout>
